# Band Platform configuration
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# LLM API Key (Google AI Studio key for Gemini)
# run_agents.py uses this key and routes to gemini-2.5-flash-lite by default.
GOOGLE_API_KEY=your-google-ai-studio-key-here

# Optional: Per-agent model overrides (CrewAI uses LiteLLM routing; prefix must be "gemini/")
# TRIAGE_AGENT_MODEL=gemini/gemini-2.5-flash-lite
# REDTEAM_AGENT_MODEL=gemini/gemini-2.5-flash-lite
# DEVELOPER_AGENT_MODEL=gemini/gemini-2.5-flash-lite
# AUDITOR_AGENT_MODEL=gemini/gemini-2.5-flash-lite
# RELEASE_AGENT_MODEL=gemini/gemini-2.5-flash-lite
