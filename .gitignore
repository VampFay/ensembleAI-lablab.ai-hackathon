# Note: top-level `dist/` is gitignored (Python build output),
# but frontend/dist/ IS committed (pre-built dashboard for zero-setup judges).
dist/
!frontend/dist/

# Virtual environments and dependencies
.venv/
venv/
ENV/
node_modules/
frontend/node_modules/

# Local configuration & environment files
.env
.env.local
.env.*.local
agent_config.yaml

