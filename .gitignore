scratch/state.db
scratch/state.db-*
scratch/agents.log
scratch/server.log
scratch/exploit_*
terminal-logs/
reports/*.md
reports/*.sig
waf_rules/*.conf
!waf_rules/test_rule.conf
.playwright-mcp/
*.tmp
*.zip

